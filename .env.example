HAMVOX_APP_HOST=0.0.0.0
HAMVOX_APP_PORT=8080

HAMVOX_RECORDINGS_ROOT_HOST=./recordings
HAMVOX_RECORDINGS_ROOT=/recordings
HAMVOX_ARCHIVE_ROOT=/recordings/archive
HAMVOX_TRANSCRIPTS_ROOT=/recordings/transcripts
HAMVOX_SETTINGS_PATH=/recordings/.radio-recorder-app/application-settings.json

HAMVOX_TIMEZONE=America/New_York

HAMVOX_ADMIN_USERNAME=admin
HAMVOX_ADMIN_PASSWORD=
HAMVOX_PROTECT_PUBLIC=false
HAMVOX_PROTECT_TRANSCRIPTS=false
HAMVOX_PROTECT_LOGS=false
HAMVOX_UI_THEME=dark

# OpenAI transcription credentials/models are configured in the web Settings page.
# These env vars are only worker timing/retry controls.
HAMVOX_TRANSCRIPTION_SCAN_SECONDS=45
HAMVOX_OPENAI_RETRY_MAX=5
HAMVOX_OPENAI_RETRY_BASE=2.0
HAMVOX_OPENAI_HOUR_SUMMARY_MAX_INPUT_CHARS=24000
HAMVOX_OPENAI_DAY_SUMMARY_MAX_INPUT_CHARS=32000
HAMVOX_OPENAI_HOUR_SUMMARY_MAX_TOKENS=500
HAMVOX_OPENAI_DAY_SUMMARY_MAX_TOKENS=750
HAMVOX_EVENT_LOG_PATH=/recordings/.radio-recorder-app/logs/events.jsonl
HAMVOX_EVENT_LOG_MAX_BYTES=10485760

ICECAST_PORT=8000
ICECAST_HOSTNAME=localhost
ICECAST_LOCATION=HamVOX Host
ICECAST_ADMIN=radio@localhost
ICECAST_SOURCE_PASSWORD=change-me-source
ICECAST_RELAY_PASSWORD=change-me-relay
ICECAST_ADMIN_PASSWORD=change-me-admin
ICECAST_STREAM_NAME=HamVOX Radio Stream
ICECAST_STREAM_DESCRIPTION=Self-hosted HamVOX live radio stream
ICECAST_STREAM_GENRE=Scanner
